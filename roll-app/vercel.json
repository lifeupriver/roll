{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/process/**/*.ts": {
      "maxDuration": 300
    },
    "src/app/api/eyeq/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/upload/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/prodigi/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup-invites",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/retry-jobs",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/cleanup-orphans",
      "schedule": "0 3 * * *"
    }
  ]
}
