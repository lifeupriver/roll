# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Cloudflare R2 ===
R2_ACCOUNT_ID=xxxxx
R2_ACCESS_KEY_ID=xxxxx
R2_SECRET_ACCESS_KEY=xxxxx
R2_BUCKET_NAME=roll-photos-dev
R2_PUBLIC_URL=https://photos.roll.photos

# === Prodigi (Print Fulfillment) ===
PRODIGI_API_KEY=xxxxx
PRODIGI_API_URL=https://api.sandbox.prodigi.com
PRODIGI_WEBHOOK_SECRET=xxxxx
ENABLE_PRINT_FULFILLMENT=false

# === Resend (Email) ===
RESEND_API_KEY=xxxxx

# === Stripe ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID_PLUS=price_xxxxx

# === PostHog ===
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Sentry ===
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# === Web Push (VAPID) ===
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxQ=
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=

# === Cron Jobs ===
# Secret used to protect cron endpoints from unauthorized access
# Generate with: openssl rand -hex 32
CRON_SECRET=xxxxx

# === AI Correction Provider ===
# Which provider to use: "eyeq" (default) or "imagen"
# CORRECTION_PROVIDER=eyeq

# --- EyeQ / Perfectly Clear (images + video) ---
# API key for the Perfectly Clear WebAPI v2.
# When not set, correction is skipped gracefully.
EYEQ_API_KEY=xxxxx
# Optional: named preset from Perfectly Clear Workbench
# EYEQ_PRESET=roll_standard

# --- Imagen AI (images only) ---
# API key from imagen-ai.com
# IMAGEN_API_KEY=xxxxx
# Profile key (trained AI editing profile, e.g. 5700)
# IMAGEN_PROFILE_KEY=5700
# Optional: photography type (WEDDING, PORTRAITS, LANDSCAPE_NATURE, etc.)
# IMAGEN_PHOTOGRAPHY_TYPE=PORTRAITS

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Roll

# === Preview Mode ===
# Set to "true" to run the app with mock data and no external services.
# Bypasses Supabase auth, uses placeholder images, skips R2/Stripe/etc.
# NEXT_PUBLIC_PREVIEW_MODE=true
